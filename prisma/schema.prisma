datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Certificate {
  id          String   @id @default(uuid())
  grade       Int      // 학년 (1~6)
  classNum    Int      // 반 (1~10)
  studentName String   // 학생 이름
  imageUrl    String   // 업로드된 이미지 경로
  createdAt   DateTime @default(now())

  @@index([grade, classNum])
}
